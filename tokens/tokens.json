{
  "$schema": "https://design-tokens.github.io/format/",
  "meta": {
    "name": "Órulo Design Tokens",
    "version": "2.0.0",
    "source": "docs/diretrizes-de-criacao.md",
    "updated": "2026-07-07",
    "nonNegotiable": ["cores oficiais", "Poppins"]
  },
  "color": {
    "branco":     { "value": "#FFFFFF", "rgb": "255,255,255", "role": "Fundo padrão do Modo Claro" },
    "offWhite":   { "value": "#F4F6FF", "rgb": "244,246,255", "role": "Fundo claro alternativo, cards suaves" },
    "azul":       { "value": "#0037FF", "rgb": "0,55,255",    "role": "Cor-marca. Fundo Modo Escuro, cards, destaques, CTA" },
    "marinho":    { "value": "#01178B", "rgb": "1,23,138",    "role": "Fundo escuro premium, texto forte, números" },
    "preto":      { "value": "#3D3D3D", "rgb": "61,61,61",    "role": "Corpo de texto sobre fundo claro" },
    "cinza":      { "value": "#7B7B7B", "rgb": "123,123,123", "role": "Texto secundário, legendas, fonte de dado" },
    "cinza2":     { "value": "#BDBDBD", "rgb": "189,189,189", "role": "Linhas finas, divisores" },
    "neon":       { "value": "#BCFF00", "rgb": "188,255,0",   "role": "Sinal: grifo de 1 palavra, selo, glow do herói. Nunca fundo grande" },
    "especial": {
      "roxo":     { "value": "#6610F5", "role": "Esporádico, nunca base" },
      "laranja":  { "value": "#FF7B37", "role": "Esporádico, nunca base" },
      "ciano":    { "value": "#10F7FE", "role": "Esporádico, nunca base" }
    }
  },
  "proportion": {
    "dominante": "70%",
    "apoio": "20%",
    "neonMax": "10%"
  },
  "typography": {
    "family": "Poppins",
    "tracking": "padrão original da Poppins (não condensar/expandir)",
    "reference": "@1080x1350",
    "scale": {
      "tituloCapa":      { "size": "96-130px", "weight": "700/800", "note": "Ocupa 30-50% do slide. Máx. 3 linhas" },
      "tituloInterno":   { "size": "60-80px",  "weight": "700",     "note": "Um por página" },
      "subtitulo":       { "size": "40-46px",  "weight": "500",     "note": "1-2 linhas, curto" },
      "corpo":           { "size": "30-34px",  "weight": "400",     "note": "Sem parágrafos longos" },
      "numeroEditorial": { "size": "160-260px","weight": "800",     "note": "Tabular. Dado-herói ou passo numerado" },
      "labelSelo":       { "size": "24-26px",  "weight": "600",     "note": "Caps" },
      "legenda":         { "size": "22px",     "weight": "400",     "note": "Cinza. Crédito do dado" }
    }
  },
  "grid": {
    "formatoMestre": "1080x1350 (4:5)",
    "outros": ["1080x1080 (quadrado)", "1080x1920 (story)"],
    "base": "8px",
    "margemExterna": "96px",
    "safeZone": { "topo": "150px", "base": "230px" },
    "raioCard": "40px"
  },
  "effects": {
    "sombra": "0 8px 28px rgba(1,23,138,.08)",
    "gradienteEscuro": "linear-gradient(160deg, #0037FF, #01178B)",
    "glow": "apenas no elemento-herói do Modo Escuro"
  },
  "logo": {
    "wordmark": "órulo",
    "proporcao": "≈ 3.32:1",
    "cores": ["#0037FF", "#FFFFFF"],
    "regra": "Fundo escuro/azul → logo branco; fundo claro → logo azul. Nunca preto, cinza, neon ou distorcido."
  }
}
